//@version=5
indicator("Riskflow Relative Strength Z + Viscosity Pressure Waves [Experimental]", overlay=false, dynamic_requests=true)

// 01. MODE / DROPDOWNS - TOP OF SETTINGS PANEL
grpTop = "01. Mode / Dropdowns"

marketMode = input.string("Crypto", "Market Mode", options=["Crypto", "Equities / Stocks"], group=grpTop)
analysisTarget = input.string("Current Chart Asset", "Analysis Target", options=["Current Chart Asset", "Selected Basket Index"], group=grpTop)
priceSourceMode = input.string("Close", "Price Source", options=["Close", "HLC3", "OHLC4", "HL2"], group=grpTop)

basketSource = input.string("Crypto Meme Broad Basket", "Selected Basket", options=["Crypto Meme Core Basket", "Crypto Meme Broad Basket", "Crypto Meme High-Beta Basket", "Crypto Custom Basket 1", "Crypto Custom Basket 2", "Crypto Custom Basket 3", "Equity Market Basket", "Equity Custom Basket 1", "Equity Custom Basket 2", "Equity Custom Basket 3"], group=grpTop)

relativeBenchmarkMode = input.string("Selected Basket", "Relative Benchmark", options=["Selected Basket", "OTHERS", "TOTALES", "TOTAL2ES", "TOTAL3ES", "BTC", "ETH", "SOL", "TON", "SPY", "QQQ", "IWM", "DIA", "VIX", "Custom Symbol", "Off"], group=grpTop)

riskEnvironmentMode = input.string("Auto", "Risk Environment", options=["Auto", "Crypto Long-Tail Risk", "Equity Risk-On", "Off"], group=grpTop)

weightPreset = input.string("Meme Leadership Default", "Weight Preset", options=["Meme Leadership Default", "Crypto Alt Default", "Equity Stock Picking Default", "Large Cap vs Benchmark", "Pure Ratio Chart", "Custom"], group=grpTop)

finalSignalNormalization = input.string("Weight-Scaled Fusion", "Final Signal Normalization", options=["Weight-Scaled Fusion", "Final Z-Score"], group=grpTop)

displayMode = input.string("Final Signal", "Display Mode", options=["Final Signal", "Price Component", "Relative Component", "Risk Component", "Fusion Before Final Z"], group=grpTop)

candleColorSource = input.string("Gradient Driver", "Candle Color Source", options=["Gradient Driver", "Signal Line"], group=grpTop)

// 02. QUICK CONTROLS
grpControl = "02. Quick Controls"

customBenchmarkSymbol = input.symbol("AMEX:SPY", "Custom Benchmark Symbol", group=grpControl)
minActiveBasketMembers = input.int(3, "Minimum Active Basket Members", minval=1, maxval=20, group=grpControl)
forceFullHistory = input.bool(true, "Force Full Price History", group=grpControl)
neverBlankSignal = input.bool(true, "Never Blank Signal", group=grpControl)

// 03. WEIGHTS / CLAMP
grpWeights = "03. Weights / Clamp"

customPriceWeight = input.float(1.20, "Custom: Asset Price Weight", step=0.05, group=grpWeights)
customRelativeWeight = input.float(0.65, "Custom: Asset vs Benchmark Weight", step=0.05, group=grpWeights)
customRiskWeight = input.float(0.85, "Custom: Risk Environment Weight", step=0.05, group=grpWeights)

componentZClamp = input.float(3.50, "Component Z Clamp", minval=1.0, maxval=10.0, step=0.25, group=grpWeights)

presetPriceWeight = weightPreset == "Meme Leadership Default" ? 1.20 : weightPreset == "Crypto Alt Default" ? 1.15 : weightPreset == "Equity Stock Picking Default" ? 1.10 : weightPreset == "Large Cap vs Benchmark" ? 1.00 : weightPreset == "Pure Ratio Chart" ? 1.00 : customPriceWeight
presetRelativeWeight = weightPreset == "Meme Leadership Default" ? 0.65 : weightPreset == "Crypto Alt Default" ? 0.85 : weightPreset == "Equity Stock Picking Default" ? 0.90 : weightPreset == "Large Cap vs Benchmark" ? 1.00 : weightPreset == "Pure Ratio Chart" ? 0.00 : customRelativeWeight
presetRiskWeight = weightPreset == "Meme Leadership Default" ? 0.85 : weightPreset == "Crypto Alt Default" ? 0.60 : weightPreset == "Equity Stock Picking Default" ? 0.50 : weightPreset == "Large Cap vs Benchmark" ? 0.25 : weightPreset == "Pure Ratio Chart" ? 0.00 : customRiskWeight

// 04. NORMALIZATION
