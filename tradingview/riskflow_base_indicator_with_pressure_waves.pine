// BASKET RETURNS
[r1, a1] = f_ret(s1)
[r2, a2] = f_ret(s2)
[r3, a3] = f_ret(s3)
[r4, a4] = f_ret(s4)
[r5, a5] = f_ret(s5)
[r6, a6] = f_ret(s6)
[r7, a7] = f_ret(s7)
[r8, a8] = f_ret(s8)
[r9, a9] = f_ret(s9)
[r10, a10] = f_ret(s10)
[r11, a11] = f_ret(s11)
[r12, a12] = f_ret(s12)
[r13, a13] = f_ret(s13)
[r14, a14] = f_ret(s14)
[r15, a15] = f_ret(s15)
[r16, a16] = f_ret(s16)
[r17, a17] = f_ret(s17)
[r18, a18] = f_ret(s18)
[r19, a19] = f_ret(s19)
[r20, a20] = f_ret(s20)

sumRet = nz(r1) + nz(r2) + nz(r3) + nz(r4) + nz(r5) + nz(r6) + nz(r7) + nz(r8) + nz(r9) + nz(r10) + nz(r11) + nz(r12) + nz(r13) + nz(r14) + nz(r15) + nz(r16) + nz(r17) + nz(r18) + nz(r19) + nz(r20)
activeCount = a1 + a2 + a3 + a4 + a5 + a6 + a7 + a8 + a9 + a10 + a11 + a12 + a13 + a14 + a15 + a16 + a17 + a18 + a19 + a20

basketReady = activeCount >= minActiveBasketMembers
avgRetRaw = basketReady and activeCount > 0 ? sumRet / activeCount : na
avgRet = not na(avgRetRaw) ? math.max(avgRetRaw, -0.95) : na

var float basketIndex = na
if not na(avgRet)
    basketIndex := na(basketIndex[1]) ? 100 : basketIndex[1] * (1 + avgRet)
else
    basketIndex := basketIndex[1]

// MARKET / BENCHMARK COMPONENTS
others = request.security("CRYPTOCAP:OTHERS", timeframe.period, close, ignore_invalid_symbol=true)
totales = request.security("CRYPTOCAP:TOTALES", timeframe.period, close, ignore_invalid_symbol=true)
total2es = request.security("CRYPTOCAP:TOTAL2ES", timeframe.period, close, ignore_invalid_symbol=true)
total3es = request.security("CRYPTOCAP:TOTAL3ES", timeframe.period, close, ignore_invalid_symbol=true)
btcMC = request.security("CRYPTOCAP:BTC", timeframe.period, close, ignore_invalid_symbol=true)
usdtD = request.security("CRYPTOCAP:USDT.D", timeframe.period, close, ignore_invalid_symbol=true)

btcPrice = f_close("CRYPTO:BTCUSD")
ethPrice = f_close("CRYPTO:ETHUSD")
solPrice = f_close("CRYPTO:SOLUSD")
tonPrice = f_close("CRYPTO:TONUSD")

spyPrice = f_close("AMEX:SPY")
qqqPrice = f_close("NASDAQ:QQQ")
iwmPrice = f_close("AMEX:IWM")
diaPrice = f_close("AMEX:DIA")
vixPrice = f_close("CBOE:VIX")

customBenchmarkClose = f_close(customBenchmarkSymbol)

benchmarkRaw = relativeBenchmarkMode == "Selected Basket" ? basketIndex : relativeBenchmarkMode == "OTHERS" ? others : relativeBenchmarkMode == "TOTALES" ? totales : relativeBenchmarkMode == "TOTAL2ES" ? total2es : relativeBenchmarkMode == "TOTAL3ES" ? total3es : relativeBenchmarkMode == "BTC" ? btcPrice : relativeBenchmarkMode == "ETH" ? ethPrice : relativeBenchmarkMode == "SOL" ? solPrice : relativeBenchmarkMode == "TON" ? tonPrice : relativeBenchmarkMode == "SPY" ? spyPrice : relativeBenchmarkMode == "QQQ" ? qqqPrice : relativeBenchmarkMode == "IWM" ? iwmPrice : relativeBenchmarkMode == "DIA" ? diaPrice : relativeBenchmarkMode == "VIX" ? vixPrice : relativeBenchmarkMode == "Custom Symbol" ? customBenchmarkClose : na

// RISK ENVIRONMENT COMPONENTS
coreAltBucket = total2es - others
btcShareNonStable = btcMC / totales

cryptoRiskValid = not na(others) and not na(total2es) and not na(btcMC) and not na(totales) and not na(usdtD) and coreAltBucket > 0 and btcShareNonStable > 0 and usdtD > 0
cryptoRiskRaw = cryptoRiskValid ? ((others / coreAltBucket) / btcShareNonStable) / usdtD : na

equityRiskValid = not na(iwmPrice) and not na(spyPrice) and not na(qqqPrice) and not na(vixPrice) and iwmPrice > 0 and spyPrice > 0 and qqqPrice > 0 and vixPrice > 0
equityRiskRaw = equityRiskValid ? (iwmPrice / spyPrice) * (qqqPrice / spyPrice) * (spyPrice / vixPrice) : na

resolvedRiskMode = riskEnvironmentMode == "Auto" and marketMode == "Crypto" ? "Crypto Long-Tail Risk" : riskEnvironmentMode == "Auto" and marketMode == "Equities / Stocks" ? "Equity Risk-On" : riskEnvironmentMode
riskRaw = resolvedRiskMode == "Crypto Long-Tail Risk" ? cryptoRiskRaw : resolvedRiskMode == "Equity Risk-On" ? equityRiskRaw : na

// TARGET / NORMALIZATION BASES
targetRaw = analysisTarget == "Current Chart Asset" ? chartPriceSource : basketIndex
useRelative = relativeBenchmarkMode != "Off" and not (analysisTarget == "Selected Basket Index" and relativeBenchmarkMode == "Selected Basket")

var float targetBase = na
var float benchmarkBase = na

if na(targetBase) and not na(targetRaw) and targetRaw > 0
    targetBase := targetRaw

if na(benchmarkBase) and useRelative and not na(benchmarkRaw) and benchmarkRaw > 0
    benchmarkBase := benchmarkRaw

targetNorm = not na(targetBase) and targetBase > 0 ? targetRaw / targetBase : na
benchmarkNorm = useRelative and not na(benchmarkBase) and benchmarkBase > 0 ? benchmarkRaw / benchmarkBase : na
targetVsBenchmark = useRelative and not na(targetNorm) and not na(benchmarkNorm) and benchmarkNorm > 0 ? targetNorm / benchmarkNorm : 1.0

// COMPONENT-NORMALIZED ENGINE WITH FULL-HISTORY BOOTSTRAP
effectivePriceWeight = presetPriceWeight
effectiveRelativeWeight = useRelative ? presetRelativeWeight : 0.0
effectiveRiskWeight = resolvedRiskMode != "Off" ? presetRiskWeight : 0.0

priceLog = not na(targetNorm) and targetNorm > 0 ? math.log(targetNorm) : na
relativeLog = useRelative and targetVsBenchmark > 0 ? math.log(targetVsBenchmark) : na
riskLog = resolvedRiskMode != "Off" and not na(riskRaw) and riskRaw > 0 ? math.log(riskRaw) : na

var int priceValidBars = 0
var int relativeValidBars = 0
var int riskValidBars = 0
var int fusionValidBars = 0

priceValidBars := not na(priceLog) ? priceValidBars + 1 : 0
relativeValidBars := not na(relativeLog) ? relativeValidBars + 1 : 0
riskValidBars := not na(riskLog) ? riskValidBars + 1 : 0

priceAdaptiveLen = math.max(2, math.min(zLen, priceValidBars))
relativeAdaptiveLen = math.max(2, math.min(zLen, relativeValidBars))
riskAdaptiveLen = math.max(2, math.min(zLen, riskValidBars))

priceZUnclamped = forceFullHistory and not na(priceLog) ? f_zscore(priceLog, priceAdaptiveLen) : priceValidBars >= minComponentWarmupBars ? f_zscore(priceLog, priceAdaptiveLen) : na
relativeZUnclamped = forceFullHistory and useRelative and not na(relativeLog) ? f_zscore(relativeLog, relativeAdaptiveLen) : useRelative and relativeValidBars >= minComponentWarmupBars ? f_zscore(relativeLog, relativeAdaptiveLen) : na
riskZUnclamped = forceFullHistory and resolvedRiskMode != "Off" and not na(riskLog) ? f_zscore(riskLog, riskAdaptiveLen) : resolvedRiskMode != "Off" and riskValidBars >= minComponentWarmupBars ? f_zscore(riskLog, riskAdaptiveLen) : na

priceComponentZRaw = not na(priceZUnclamped) ? f_clamp(priceZUnclamped, -componentZClamp, componentZClamp) : na
relativeComponentZRaw = not na(relativeZUnclamped) ? f_clamp(relativeZUnclamped, -componentZClamp, componentZClamp) : na
riskComponentZRaw = not na(riskZUnclamped) ? f_clamp(riskZUnclamped, -componentZClamp, componentZClamp) : na

priceComponentZ = priceComponentZRaw
relativeComponentZ = effectiveRelativeWeight == 0.0 ? 0.0 : relativeComponentZRaw
riskComponentZ = effectiveRiskWeight == 0.0 ? 0.0 : riskComponentZRaw

priceReady = not na(priceComponentZ)
relativeReady = effectiveRelativeWeight == 0.0 or not na(relativeComponentZ)
riskReady = effectiveRiskWeight == 0.0 or not na(riskComponentZ)

availablePriceWeight = priceReady ? effectivePriceWeight : 0.0
availableRelativeWeight = relativeReady and effectiveRelativeWeight != 0.0 ? effectiveRelativeWeight : 0.0
availableRiskWeight = riskReady and effectiveRiskWeight != 0.0 ? effectiveRiskWeight : 0.0

availableWeightPower = math.sqrt(math.pow(availablePriceWeight, 2) + math.pow(availableRelativeWeight, 2) + math.pow(availableRiskWeight, 2))

fusionWeightedRaw = priceReady ? (availablePriceWeight * nz(priceComponentZ, 0.0)) + (availableRelativeWeight * nz(relativeComponentZ, 0.0)) + (availableRiskWeight * nz(riskComponentZ, 0.0)) : na
fusionWeightScaled = not na(fusionWeightedRaw) and availableWeightPower > 0 ? fusionWeightedRaw / availableWeightPower : na

fusionValidBars := not na(fusionWeightScaled) ? fusionValidBars + 1 : 0
fusionAdaptiveLen = math.max(2, math.min(zLen, fusionValidBars))

fusionFinalZ = forceFullHistory and not na(fusionWeightScaled) ? f_zscore(fusionWeightScaled, fusionAdaptiveLen) : fusionValidBars >= minComponentWarmupBars ? f_zscore(fusionWeightScaled, fusionAdaptiveLen) : na

finalSignalRaw = finalSignalNormalization == "Final Z-Score" ? fusionFinalZ : fusionWeightScaled

engineSignal = not na(finalSignalRaw) ? finalSignalRaw : not na(priceComponentZRaw) ? priceComponentZRaw : neverBlankSignal ? 0.0 : na

displayCandidate = displayMode == "Price Component" ? priceComponentZRaw : displayMode == "Relative Component" ? relativeComponentZ : displayMode == "Risk Component" ? riskComponentZ : displayMode == "Fusion Before Final Z" ? fusionWeightScaled : engineSignal

signalLine = neverBlankSignal ? not na(displayCandidate) ? displayCandidate : engineSignal : displayCandidate
simpleSmooth = ta.ema(signalLine, smoothLen)

priceComponentActive = not na(priceComponentZRaw) ? 1.0 : 0.0
relativeComponentActive = effectiveRelativeWeight != 0.0 and not na(relativeComponentZRaw) ? 1.0 : 0.0
riskComponentActive = effectiveRiskWeight != 0.0 and not na(riskComponentZRaw) ? 1.0 : 0.0

fullEngineActive = priceValidBars >= minComponentWarmupBars and (effectiveRelativeWeight == 0.0 or relativeValidBars >= minComponentWarmupBars) and (effectiveRiskWeight == 0.0 or riskValidBars >= minComponentWarmupBars) ? 1.0 : 0.0

// DISPLAY VISCOSITY BASELINE
zDeltaAbs = not na(signalLine) ? math.abs(signalLine - nz(signalLine[1], signalLine)) : 0.0
zChange = not na(signalLine[visLen]) and not na(signalLine) ? math.abs(signalLine - signalLine[visLen]) : 0.0
zVolatility = math.sum(zDeltaAbs, visLen)

er = zVolatility != 0 ? zChange / zVolatility : 0.0

fastSC = 2.0 / (fastLen + 1.0)
slowSC = 2.0 / (slowLen + 1.0)
baseSC = math.pow(er * (fastSC - slowSC) + slowSC, 2)

zStep = signalLine - nz(signalLine[1], signalLine)
stepAvg = ta.ema(math.abs(zStep), visLen)
stepImpulse = stepAvg != 0 ? f_clamp(math.abs(zStep) / stepAvg, 0.0, 3.0) / 3.0 : 0.0

zeroProximity = 1.0 - f_clamp(math.abs(signalLine) / 2.0, 0.0, 1.0)

adaptiveSC = baseSC * (1.0 + impulseBoost * stepImpulse + zeroZoneBoost * zeroProximity * stepImpulse)
adaptiveSC := f_clamp(adaptiveSC, 0.001, 1.0)

var float viscosity = na
viscosity := na(viscosity[1]) or na(signalLine) ? signalLine : viscosity[1] + adaptiveSC * (signalLine - viscosity[1])

// DISPLAY GRADIENT DRIVER
zSlope = signalLine - nz(signalLine[1], signalLine)
zAccel = zSlope - nz(zSlope[1], zSlope)

slopeVol = ta.stdev(zSlope, visLen)
accelVol = ta.stdev(zAccel, visLen)

slopeNorm = slopeVol != 0 and not na(slopeVol) ? f_clamp(zSlope / slopeVol, -2.0, 2.0) : 0.0
accelNorm = accelVol != 0 and not na(accelVol) ? f_clamp(zAccel / accelVol, -2.0, 2.0) : 0.0

distanceFromViscosity = signalLine - viscosity

fusionDriverRaw = signalLine + (velocityWeight * distanceFromViscosity) + (slopeWeight * slopeNorm) + (accelWeight * accelNorm)
fusionDriverSmooth = ta.ema(fusionDriverRaw, gradientSmoothLen)
fusionDriverBlended = (fusionDriverRaw * (1.0 - gradientSmoothBlend)) + (fusionDriverSmooth * gradientSmoothBlend)

gradientDriver = fusionDriverBlended * gradientIntensity

safeGradientForLine = nz(gradientDriver, nz(signalLine, 0.0))
signalColor = f_hydraulic_color(safeGradientForLine)

// ENGINE VISCOSITY / GRADIENT FOR CANDLE COLORS
engineSignalSafe = nz(engineSignal, 0.0)

engineDeltaAbs = math.abs(engineSignalSafe - nz(engineSignalSafe[1], engineSignalSafe))
engineChange = math.abs(engineSignalSafe - nz(engineSignalSafe[visLen], engineSignalSafe))
engineVolatility = math.sum(engineDeltaAbs, visLen)

engineEr = engineVolatility != 0 ? engineChange / engineVolatility : 0.0
engineBaseSC = math.pow(engineEr * (fastSC - slowSC) + slowSC, 2)

engineStep = engineSignalSafe - nz(engineSignalSafe[1], engineSignalSafe)
engineStepAvg = ta.ema(math.abs(engineStep), visLen)
engineStepImpulse = engineStepAvg != 0 ? f_clamp(math.abs(engineStep) / engineStepAvg, 0.0, 3.0) / 3.0 : 0.0

engineZeroProximity = 1.0 - f_clamp(math.abs(engineSignalSafe) / 2.0, 0.0, 1.0)

engineAdaptiveSC = engineBaseSC * (1.0 + impulseBoost * engineStepImpulse + zeroZoneBoost * engineZeroProximity * engineStepImpulse)
engineAdaptiveSC := f_clamp(engineAdaptiveSC, 0.001, 1.0)

var float engineViscosity = na
engineViscosity := na(engineViscosity[1]) ? engineSignalSafe : engineViscosity[1] + engineAdaptiveSC * (engineSignalSafe - engineViscosity[1])

engineSlope = engineSignalSafe - nz(engineSignalSafe[1], engineSignalSafe)
engineAccel = engineSlope - nz(engineSlope[1], engineSlope)

engineSlopeVol = ta.stdev(engineSlope, visLen)
engineAccelVol = ta.stdev(engineAccel, visLen)

engineSlopeNorm = engineSlopeVol != 0 and not na(engineSlopeVol) ? f_clamp(engineSlope / engineSlopeVol, -2.0, 2.0) : 0.0
engineAccelNorm = engineAccelVol != 0 and not na(engineAccelVol) ? f_clamp(engineAccel / engineAccelVol, -2.0, 2.0) : 0.0

engineDistanceFromViscosity = engineSignalSafe - engineViscosity

engineGradientRaw = engineSignalSafe + (velocityWeight * engineDistanceFromViscosity) + (slopeWeight * engineSlopeNorm) + (accelWeight * engineAccelNorm)
engineGradientSmooth = ta.ema(engineGradientRaw, gradientSmoothLen)
engineGradientBlended = (engineGradientRaw * (1.0 - gradientSmoothBlend)) + (engineGradientSmooth * gradientSmoothBlend)

engineGradientDriver = engineGradientBlended * gradientIntensity

// VISCOSITY PRESSURE WAVES
// Raw area is retained in the data window; visible waves use normalized pressure distance for smoother curvature.
pressureSignal = pressureWaveSource == "Display Signal" ? nz(signalLine, 0.0) : engineSignalSafe
pressureBaseline = pressureWaveSource == "Display Signal" ? nz(viscosity, pressureSignal) : engineViscosity
pressureDistance = pressureSignal - pressureBaseline

pressurePositive = math.max(pressureDistance, 0.0)
pressureNegative = math.max(-pressureDistance, 0.0)

pressurePositiveAreaShort = math.sum(pressurePositive, pressureShortLen)
pressureNegativeAreaShort = math.sum(pressureNegative, pressureShortLen)
pressureTotalAreaShort = pressurePositiveAreaShort + pressureNegativeAreaShort
pressureNetAreaShort = pressurePositiveAreaShort - pressureNegativeAreaShort

pressurePositiveAreaLong = math.sum(pressurePositive, pressureLongLen)
pressureNegativeAreaLong = math.sum(pressureNegative, pressureLongLen)
pressureTotalAreaLong = pressurePositiveAreaLong + pressureNegativeAreaLong
pressureNetAreaLong = pressurePositiveAreaLong - pressureNegativeAreaLong

pressureAbsBase = ta.ema(math.abs(pressureDistance), pressureNormalizeLen)
pressureNormalizedDistance = pressureAbsBase > 0 and not na(pressureAbsBase) ? f_clamp(pressureDistance / pressureAbsBase, -3.0, 3.0) : 0.0
pressureWaveShortRaw = ta.ema(pressureNormalizedDistance, pressureShortLen)
pressureWaveLongRaw = ta.ema(pressureNormalizedDistance, pressureLongLen)
pressureWaveShort = ta.ema(pressureWaveShortRaw, pressureSmoothLen) * pressureScale
pressureWaveLong = ta.ema(pressureWaveLongRaw, pressureSmoothLen) * pressureScale

pressureWaveDelta = pressureWaveShort - pressureWaveLong
pressurePositiveShareShort = pressureTotalAreaShort > 0 ? pressurePositiveAreaShort / pressureTotalAreaShort : na
pressurePositiveShareLong = pressureTotalAreaLong > 0 ? pressurePositiveAreaLong / pressureTotalAreaLong : na

pressureShortColor = color.new(cPressureShort, 35)
pressureLongColor = color.new(cPressureLong, 55)
pressureHistColor = pressureWaveDelta >= 0 ? color.new(cPressureShort, 82) : color.new(cPressureLong, 86)

// PLOTTING
plot(signalLine, "Signal Line / Display Mode", color=signalColor, linewidth=lineWidth)
plot(showViscosityMA ? viscosity : na, "Adaptive Viscosity Baseline", color=color.new(color.white, 35), linewidth=1)
plot(showSimpleMA ? simpleSmooth : na, "Simple Smooth", color=color.new(color.gray, 35), linewidth=1)

pressureShortPlot = plot(showPressureWaves ? pressureWaveShort : na, "Short Viscosity Pressure Wave", color=pressureShortColor, linewidth=2)
pressureLongPlot = plot(showPressureWaves ? pressureWaveLong : na, "Long Viscosity Pressure Wave", color=pressureLongColor, linewidth=2)
plot(showPressureWaves and showPressureHistogram ? pressureWaveDelta : na, "Short - Long Pressure Histogram", style=plot.style_columns, color=pressureHistColor)
fill(pressureShortPlot, pressureLongPlot, color=showPressureWaves ? color.new(cPressureShort, 88) : na, title="Pressure Wave Fill")

hline(2.0, "+2sigma / Overheated", color=cHydraulicRed, linestyle=hline.style_dotted)
hline(1.5, "+1.5sigma / Upper Gate", color=cHydraulicOrange, linestyle=hline.style_dotted)
hline(0.0, "0 / Equilibrium", color=cHydraulicGray, linestyle=hline.style_dotted)
hline(-1.5, "-1.5sigma / Lower Gate", color=cHydraulicLimeGate, linestyle=hline.style_dotted)
hline(-2.0, "-2sigma / Deep Value", color=cHydraulicGreen, linestyle=hline.style_dotted)

// Candle colors are driven by the real engine signal, not Display Mode.
// This lets you inspect components without changing main chart candle color logic.
candleDriver = candleColorSource == "Gradient Driver" ? engineGradientDriver : engineSignalSafe
candleColor = colorCandles ? f_hydraulic_color(candleDriver) : na

barcolor(candleColor)

overlayCandleColor = colorCandles and colorWicksBorders ? candleColor : na
plotcandle(open, high, low, close, title="Colored Overlay Candles / Wicks / Borders", color=overlayCandleColor, wickcolor=overlayCandleColor, bordercolor=overlayCandleColor, force_overlay=true)

// DEBUG
plot(showDebug ? chartPriceValid : na, "Chart Price Valid", color=color.white, display=display.data_window)
plot(showDebug ? priceSourceMovement : na, "Price Source Movement", color=color.gray, display=display.data_window)

plot(showDebug ? activeCount : na, "Active Basket Count", color=color.blue, display=display.data_window)
plot(showDebug ? basketIndex : na, "Selected Basket Index", color=color.purple, display=display.data_window)
plot(showDebug ? targetVsBenchmark : na, "Target vs Benchmark", color=color.orange, display=display.data_window)

plot(showDebug ? cryptoRiskRaw : na, "Crypto Long-Tail Risk Raw", color=color.white, display=display.data_window)
plot(showDebug ? equityRiskRaw : na, "Equity Risk-On Raw", color=color.aqua, display=display.data_window)

plot(showDebug ? priceComponentZRaw : na, "Price Component Z", color=color.green, display=display.data_window)
plot(showDebug ? relativeComponentZ : na, "Relative Component Z", color=color.yellow, display=display.data_window)
plot(showDebug ? riskComponentZ : na, "Risk Component Z", color=color.red, display=display.data_window)

plot(showDebug ? fusionWeightedRaw : na, "Fusion Weighted Raw", color=color.orange, display=display.data_window)
plot(showDebug ? fusionWeightScaled : na, "Fusion Weight-Scaled", color=color.fuchsia, display=display.data_window)
plot(showDebug ? fusionFinalZ : na, "Fusion Final Z", color=color.lime, display=display.data_window)
plot(showDebug ? engineSignal : na, "Engine Signal / Final Fallback", color=color.white, display=display.data_window)

plot(showDebug ? availablePriceWeight : na, "Available Price Weight", color=color.green, display=display.data_window)
plot(showDebug ? availableRelativeWeight : na, "Available Relative Weight", color=color.yellow, display=display.data_window)
plot(showDebug ? availableRiskWeight : na, "Available Risk Weight", color=color.red, display=display.data_window)

plot(showDebug ? priceComponentActive : na, "Price Component Active", color=color.green, display=display.data_window)
plot(showDebug ? relativeComponentActive : na, "Relative Component Active", color=color.yellow, display=display.data_window)
plot(showDebug ? riskComponentActive : na, "Risk Component Active", color=color.red, display=display.data_window)
plot(showDebug ? fullEngineActive : na, "Full Engine Active / Mature", color=color.white, display=display.data_window)

plot(showDebug ? gradientDriver : na, "Display Gradient Driver", color=color.fuchsia, display=display.data_window)
plot(showDebug ? engineGradientDriver : na, "Engine Gradient Driver", color=color.aqua, display=display.data_window)

plot(showPressureAreaInDataWindow ? pressurePositiveAreaShort : na, "Short Positive Viscosity Area", color=color.red, display=display.data_window)
plot(showPressureAreaInDataWindow ? pressureNegativeAreaShort : na, "Short Negative Viscosity Area", color=color.green, display=display.data_window)
plot(showPressureAreaInDataWindow ? pressureNetAreaShort : na, "Short Net Viscosity Area", color=color.orange, display=display.data_window)
plot(showPressureAreaInDataWindow ? pressurePositiveAreaLong : na, "Long Positive Viscosity Area", color=color.red, display=display.data_window)
plot(showPressureAreaInDataWindow ? pressureNegativeAreaLong : na, "Long Negative Viscosity Area", color=color.green, display=display.data_window)
plot(showPressureAreaInDataWindow ? pressureNetAreaLong : na, "Long Net Viscosity Area", color=color.white, display=display.data_window)
plot(showPressureAreaInDataWindow ? pressurePositiveShareShort : na, "Short Positive Pressure Share", color=color.orange, display=display.data_window)
plot(showPressureAreaInDataWindow ? pressurePositiveShareLong : na, "Long Positive Pressure Share", color=color.white, display=display.data_window)
