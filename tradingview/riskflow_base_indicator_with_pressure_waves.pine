pressureNormalizeLen = input.int(100, "Pressure Normalization Length", minval=10, maxval=500, group=grpPressure)
pressureScale = input.float(1.15, "Pressure Wave Scale", minval=0.25, maxval=6.0, step=0.05, group=grpPressure)
showPressureHistogram = input.bool(false, "Show Short-vs-Long Pressure Histogram", group=grpPressure)
showPressureAreaInDataWindow = input.bool(false, "Show Raw Pressure Area In Data Window", group=grpPressure)

// 07. DISPLAY
grpDisplay = "07. Display"

