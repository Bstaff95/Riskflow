// HELPERS
f_clamp(x, lo, hi) =>
    math.max(lo, math.min(hi, x))

f_zscore(src, len) =>
    m = ta.sma(src, len)
    d = ta.stdev(src, len)
    z = d != 0 and not na(d) ? (src - m) / d : 0.0
    not na(src) ? z : na

f_close(sym) =>
    enabled = str.length(sym) > 0
    safeSym = enabled ? sym : "CRYPTO:DOGEUSD"
    request.security(safeSym, timeframe.period, close, ignore_invalid_symbol=true)

f_ret(sym) =>
    enabled = str.length(sym) > 0
    safeSym = enabled ? sym : "CRYPTO:DOGEUSD"
    c = request.security(safeSym, timeframe.period, close, ignore_invalid_symbol=true)
    r = enabled and not na(c) and not na(c[1]) and c[1] != 0 ? (c / c[1]) - 1 : na
    active = enabled and not na(r) ? 1 : 0
    [r, active]

f_hydraulic_color(x) =>
    extreme = math.max(colorExtremeLevel, 0.1)
    driver = f_clamp(x, -extreme, extreme)
    driver >= 0 ? color.from_gradient(driver, 0.0, extreme, cHydraulicYellow, cHydraulicRed) : color.from_gradient(driver, -extreme, 0.0, cHydraulicGreen, cHydraulicYellow)

